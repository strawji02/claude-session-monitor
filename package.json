{
  "name": "claude-session-monitor",
  "displayName": "Claude Session Monitor",
  "description": "Monitor multiple Claude Code CLI sessions - see which needs attention and click to jump",
  "version": "0.3.0",
  "publisher": "planfit",
  "engines": {
    "vscode": "^1.93.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "claude-session-monitor.showSession",
        "title": "Claude: Show Session"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "claudeSessions",
          "title": "Claude Sessions",
          "icon": "$(hubot)"
        }
      ]
    },
    "views": {
      "scm": [
        {
          "id": "claudeSessionMonitor",
          "name": "Claude Sessions",
          "icon": "$(hubot)",
          "contextualTitle": "Claude Sessions"
        }
      ]
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/vscode": "^1.93.0",
    "@types/node": "^20.0.0",
    "typescript": "^5.0.0"
  }
}